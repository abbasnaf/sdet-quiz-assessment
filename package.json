{
  "name": "asynchronous-quiz-evaluation-leaderboard-system",
  "private": true,
  "packageManager": "bun@1.2.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "test:perf": "turbo run test:perf",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:migrate": "bun run --cwd packages/db migrate"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  }
}
