{
  "name": "@quiz/testing",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./playwright": "./src/playwright.ts",
    "./testcontainers": "./src/testcontainers.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "test": "bun test src/component/concurrency.test.ts",
    "test:e2e": "playwright test --config ../../apps/web/playwright.config.ts",
    "test:perf": "mkdir -p dist && k6 run scripts/leaderboard.perf.js --summary-export dist/perf-results.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@playwright/test": "^1.53.1",
    "testcontainers": "^10.28.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.17",
    "@types/node": "^22.15.32"
  }
}
