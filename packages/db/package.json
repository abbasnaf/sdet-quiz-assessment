    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.2",
    "ioredis": "^5.6.1"
  },
  "devDependencies": {
    "@types/bun": "^1.2.17",
    "drizzle-kit": "^0.31.1"
  }
